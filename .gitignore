# ============================================================
#  Octopus Agents V2 — Git ignore rules
# ============================================================

# ---- Secrets / environment ----
.env
.env.*
!.env.example

# ---- IDE / Claude-Code session state ----
.claude/
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
venv/
.venv/
env/

# ---- Node / frontend ----
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Local data — never ship operator state ----
database/octopus.db
database/octopus.db-journal
database/octopus.db-shm
database/octopus.db-wal
database/LLM/
*.db
*.sqlite
*.sqlite3

# ---- Logs ----
*.log
*.log.*
logs/
pipeline.log

# ---- Memory / vault snapshots ----
vault/
memory/
memory/journal.jsonl

# ---- OS / archive cruft ----
*.bak
*.tmp
*.orig
nul

# ---- Build artifacts ----
build/
dist/
*.tar.gz
*.zip

# ---- Optional: archived legacy code (operator can decide) ----
# archive/
