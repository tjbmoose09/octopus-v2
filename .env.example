# ============================================================
#  Octopus Agents V2 — .env template
#  Copy to .env and fill in your own values. Do NOT commit .env.
# ============================================================

# --- LM Studio (Local) ---
LM_STUDIO_URL=http://localhost:1234
# LM Studio's REST API does not validate this token, but the client
# requires SOME header. Any non-empty string works.
LM_STUDIO_API_KEY=lm-studio-local-token
LM_STUDIO_MODEL=nemomix-unleashed-12b
LM_STUDIO_MAX_TOKENS=4096
LM_STUDIO_CONTEXT_WINDOW=32768
LM_STUDIO_TIMEOUT=120

# --- Claude API (optional, for hybrid offloading) ---
# Get a key from https://console.anthropic.com/settings/keys
# Leave blank to run fully local.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Octopus Server ---
OCTOPUS_HOST=0.0.0.0
OCTOPUS_PORT=8080
# local | cloud | hybrid
OCTOPUS_PROVIDER_MODE=local

# --- Model assignments per role ---
# These should match exact LM Studio model IDs visible in the
# "My Models" tab. Engine does fuzzy fallback if not found.
ORCHESTRATOR_MODEL=qwen3.5-27b-claude-4.6-opus-reasoning-distilled
MODEL_ORCHESTRATOR=qwen3.5-27b-claude-4.6-opus-reasoning-distilled
MODEL_PM=mistralai/devstral-small-2-2512
MODEL_DEV=phi4-nvidia-coder
MODEL_QA=google/gemma-4-26b-a4b
MODEL_CRITIC=gemma-4-31b-it
MODEL_REVIEW=zai-org/glm-4.7-flash
MODEL_DEVOPS=qwen/qwen3.5-9b
MODEL_AUTOMATION=nemomix-unleashed-12b
MODEL_RESEARCH=qwen/qwen3.5-35b-a3b

# --- Obsidian Local REST plugin (memory backend) ---
# Install plugin: https://github.com/coddingtonbear/obsidian-local-rest-api
# Generate key inside Obsidian → Settings → Community Plugins → Local REST API
OBSIDIAN_URL=http://localhost:27123
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT=OctopusMemory
